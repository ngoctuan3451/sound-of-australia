{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 380,
  "title": {
    "text": "Every Time an Australian Hit #1 on the US Billboard Hot 100",
    "subtitle": "1971–2021. Each circle is one #1 hit. Size = weeks spent at #1 in the USA. Colour = the era it belonged to.",
    "fontSize": 19,
    "subtitleFontSize": 12,
    "font": "Playfair Display",
    "subtitleColor": "#888",
    "anchor": "start"
  },
  "config": {"view": {"stroke": null}, "font": "Inter, system-ui, sans-serif"},
  "data": {"url": "https://raw.githubusercontent.com/ngoctuan3451/FIT2179/main/data/derived/aus_billboard_no1s.json"},
  "layer": [
    {
      "mark": {"type": "circle", "opacity": 0.85, "stroke": "white", "strokeWidth": 1.5},
      "encoding": {
        "x": {
          "field": "year",
          "type": "quantitative",
          "title": null,
          "scale": {"domain": [1970, 2022], "nice": false},
          "axis": {"format": "d", "grid": false, "labelFontSize": 11, "labelColor": "#555", "values": [1971, 1980, 1990, 2000, 2010, 2021]}
        },
        "y": {
          "field": "weeks_at_1",
          "type": "quantitative",
          "title": "Weeks at #1 (Billboard Hot 100)",
          "scale": {"domain": [0, 12]},
          "axis": {"grid": true, "gridOpacity": 0.15, "labelFontSize": 11, "titleFontSize": 11, "titleColor": "#666"}
        },
        "size": {
          "field": "weeks_at_1",
          "type": "quantitative",
          "scale": {"range": [120, 1200]},
          "legend": {
            "title": "Weeks at #1",
            "orient": "bottom",
            "direction": "horizontal",
            "values": [2, 5, 10],
            "symbolFillColor": "#bbb",
            "symbolStrokeColor": "#888",
            "labelFontSize": 10,
            "titleFontSize": 11,
            "symbolOpacity": 0.7,
            "padding": 4,
            "offset": 8
          }
        },
        "color": {
          "field": "era",
          "type": "nominal",
          "scale": {
            "domain": ["70s/80s legacy", "90s/00s wave", "Streaming era"],
            "range":  ["#2980b9", "#16a085", "#f39c12"]
          },
          "legend": {
            "orient": "bottom",
            "direction": "horizontal",
            "title": "Era",
            "labelFontSize": 12,
            "titleFontSize": 11,
            "symbolSize": 200,
            "padding": 4,
            "offset": 8
          }
        },
        "tooltip": [
          {"field": "year",       "title": "Year"},
          {"field": "artist",     "title": "Artist"},
          {"field": "song",       "title": "Song"},
          {"field": "weeks_at_1", "title": "Weeks at #1"}
        ]
      }
    },
    {
      "transform": [{"filter": "datum.weeks_at_1 >= 7"}],
      "mark": {"type": "text", "align": "center", "fontSize": 10, "fontWeight": 700, "color": "#1a1a2e", "dy": -22},
      "encoding": {
        "x": {"field": "year", "type": "quantitative"},
        "y": {"field": "weeks_at_1", "type": "quantitative"},
        "text": {"field": "song"}
      }
    },
    {
      "data": {"values": [
        {"x": 2006.5, "y": 9.5, "t": "15-year gap|Savage Garden (1999) to Iggy Azalea (2014)"}
      ]},
      "mark": {"type": "text", "align": "center", "fontSize": 11, "fontStyle": "italic", "fontWeight": 700, "color": "#c0392b", "lineBreak": "|", "lineHeight": 13},
      "encoding": {
        "x": {"field": "x", "type": "quantitative"},
        "y": {"field": "y", "type": "quantitative"},
        "text": {"field": "t"}
      }
    },
    {
      "mark": {"type": "rule", "color": "#ccc", "strokeDash": [3, 3], "strokeWidth": 1},
      "encoding": {
        "x": {"datum": 1999, "type": "quantitative"}
      }
    },
    {
      "mark": {"type": "rule", "color": "#ccc", "strokeDash": [3, 3], "strokeWidth": 1},
      "encoding": {
        "x": {"datum": 2014, "type": "quantitative"}
      }
    }
  ]
}

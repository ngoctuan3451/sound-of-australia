{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 380,
  "title": {
    "text": "Few artists stay in the Hottest 100 for years",
    "subtitle": "Artists with 3+ entries. Right = more years; up = more songs; colour = best rank group.",
    "fontSize": 19,
    "subtitleFontSize": 12,
    "font": "Playfair Display",
    "subtitleColor": "#888",
    "anchor": "start"
  },
  "config": {"view": {"stroke": null}, "font": "Inter, system-ui, sans-serif"},
  "data": {"url": "https://raw.githubusercontent.com/ngoctuan3451/FIT2179/main/data/derived/h100_longevity.json"},
  "layer": [
    {
      "transform": [
        {
          "calculate": "datum.best == 1 ? '#1' : datum.best == 2 ? '#2' : datum.best == 3 ? '#3' : datum.best == 4 ? '#4' : datum.best <= 10 ? '#5-10' : datum.best <= 25 ? '#11-25' : datum.best <= 50 ? '#26-50' : '#51-100'",
          "as": "best_band"
        }
      ],
      "mark": {"type": "circle", "opacity": 0.75, "stroke": "white", "strokeWidth": 0.5},
      "encoding": {
        "x": {
          "field": "span",
          "type": "quantitative",
          "title": "Career span in the Hottest 100 (years)",
          "scale": {"domain": [0, 33], "nice": false},
          "axis": {"grid": true, "gridOpacity": 0.15, "labelFontSize": 11, "titleFontSize": 11, "titleColor": "#666"}
        },
        "y": {
          "field": "total",
          "type": "quantitative",
          "title": "Total songs voted in",
          "scale": {"domain": [0, 31]},
          "axis": {"grid": true, "gridOpacity": 0.15, "labelFontSize": 11, "titleFontSize": 11, "titleColor": "#666"}
        },
        "size": {
          "field": "total",
          "type": "quantitative",
          "scale": {"range": [40, 700]},
          "legend": {
            "title": "Total songs (dot size)",
            "orient": "right",
            "direction": "vertical",
            "values": [5, 15, 25],
            "symbolFillColor": "#d8d2dc",
            "symbolStrokeColor": "#8a8792",
            "labelFontSize": 10,
            "titleFontSize": 11
          }
        },
        "color": {
          "field": "best_band",
          "type": "ordinal",
          "scale": {
            "domain": ["#1", "#2", "#3", "#4", "#5-10", "#11-25", "#26-50", "#51-100"],
            "range": ["#ff2f75", "#00a99d", "#ffb000", "#6c3a8c", "#1cc7d0", "#b92752", "#7b7484", "#d8d2dc"]
          },
          "legend": {"title": "Best position ever reached", "orient": "right", "direction": "vertical", "titleFontSize": 11, "labelFontSize": 10, "symbolSize": 120}
        },
        "tooltip": [
          {"field": "artist", "title": "Artist"},
          {"field": "total", "title": "Total songs"},
          {"field": "span", "title": "Career span (yrs)"},
          {"field": "best", "title": "Best position"},
          {"field": "first", "title": "First poll"},
          {"field": "last",  "title": "Last poll"}
        ]
      }
    },
    {
      "transform": [
        {"window": [{"op": "rank", "as": "label_rank"}], "sort": [{"field": "total", "order": "descending"}]},
        {"filter": "datum.label_rank <= 8"}
      ],
      "mark": {"type": "text", "fontSize": 11, "fontWeight": 600, "color": "#17131f", "dx": 10, "dy": -4, "align": "left"},
      "encoding": {
        "x": {"field": "span", "type": "quantitative"},
        "y": {"field": "total", "type": "quantitative"},
        "text": {"field": "artist"}
      }
    },
    {
      "data": {"values": [
        {"x": 1.1,  "y": 28.4, "t": "BURN BRIGHT ↑",  "sub": "lots of songs, short career"},
        {"x": 31.4, "y": 28.4, "t": "LEGENDS →",      "sub": "lots of songs, long career"}
      ]},
      "layer": [
        {
          "mark": {"type": "text", "fontSize": 11, "fontWeight": 700, "color": "#7b7484", "baseline": "top"},
          "encoding": {
            "x": {"field": "x", "type": "quantitative"},
            "y": {"field": "y", "type": "quantitative"},
            "text": {"field": "t"},
            "align": {"condition": [{"test": "datum.x < 10", "value": "left"}], "value": "right"}
          }
        },
        {
          "mark": {"type": "text", "fontSize": 10, "fontStyle": "italic", "color": "#5e5a68", "baseline": "top", "dy": 14},
          "encoding": {
            "x": {"field": "x", "type": "quantitative"},
            "y": {"field": "y", "type": "quantitative"},
            "text": {"field": "sub"},
            "align": {"condition": [{"test": "datum.x < 10", "value": "left"}], "value": "right"}
          }
        }
      ]
    }
  ]
}

{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 380,
  "title": {
    "text": "Hottest 100 artists: short bursts vs long careers",
    "subtitle": "Each dot is one artist. Placed left-to-right by how many years their career spanned; bottom-to-top by how many songs they had voted in. Colour shows their best-ever position.",
    "fontSize": 19,
    "subtitleFontSize": 12,
    "font": "Playfair Display",
    "subtitleColor": "#888",
    "anchor": "start"
  },
  "config": {"view": {"stroke": null}, "font": "Inter, system-ui, sans-serif"},
  "data": {"url": "https://raw.githubusercontent.com/ngoctuan3451/FIT2179/main/data/derived/h100_longevity.json"},
  "layer": [
    {
      "mark": {"type": "circle", "opacity": 0.75, "stroke": "white", "strokeWidth": 0.5},
      "encoding": {
        "x": {
          "field": "span",
          "type": "quantitative",
          "title": "Career span in the Hottest 100 (years)",
          "scale": {"domain": [0, 33], "nice": false},
          "axis": {"grid": true, "gridOpacity": 0.15, "labelFontSize": 11, "titleFontSize": 11, "titleColor": "#666"}
        },
        "y": {
          "field": "total",
          "type": "quantitative",
          "title": "Total songs voted in",
          "scale": {"domain": [0, 30]},
          "axis": {"grid": true, "gridOpacity": 0.15, "labelFontSize": 11, "titleFontSize": 11, "titleColor": "#666"}
        },
        "size": {
          "field": "total",
          "type": "quantitative",
          "scale": {"range": [40, 700]},
          "legend": {
            "title": "Total songs (dot size)",
            "orient": "bottom",
            "direction": "horizontal",
            "values": [5, 15, 25],
            "symbolFillColor": "#bbb",
            "symbolStrokeColor": "#888",
            "labelFontSize": 10,
            "titleFontSize": 11
          }
        },
        "color": {
          "field": "best",
          "type": "quantitative",
          "scale": {"scheme": "viridis", "reverse": true, "domain": [1, 100]},
          "legend": {"title": "Best position ever reached", "orient": "bottom", "direction": "horizontal", "gradientLength": 200, "titleFontSize": 11, "labelFontSize": 10}
        },
        "tooltip": [
          {"field": "artist", "title": "Artist"},
          {"field": "total", "title": "Total songs"},
          {"field": "span", "title": "Career span (yrs)"},
          {"field": "best", "title": "Best position"},
          {"field": "first", "title": "First poll"},
          {"field": "last",  "title": "Last poll"}
        ]
      }
    },
    {
      "transform": [
        {"window": [{"op": "rank", "as": "label_rank"}], "sort": [{"field": "total", "order": "descending"}]},
        {"filter": "datum.label_rank <= 8"}
      ],
      "mark": {"type": "text", "fontSize": 11, "fontWeight": 600, "color": "#1a1a2e", "dx": 10, "dy": -4, "align": "left"},
      "encoding": {
        "x": {"field": "span", "type": "quantitative"},
        "y": {"field": "total", "type": "quantitative"},
        "text": {"field": "artist"}
      }
    },
    {
      "data": {"values": [
        {"x": 2,  "y": 29, "t": "↑ BURN BRIGHT",  "sub": "lots of songs, short career"},
        {"x": 30, "y": 29, "t": "LEGENDS →",      "sub": "lots of songs, long career"}
      ]},
      "layer": [
        {
          "mark": {"type": "text", "fontSize": 11, "fontWeight": 700, "color": "#888"},
          "encoding": {
            "x": {"field": "x", "type": "quantitative"},
            "y": {"field": "y", "type": "quantitative"},
            "text": {"field": "t"},
            "align": {"condition": [{"test": "datum.x < 10", "value": "left"}], "value": "right"}
          }
        },
        {
          "mark": {"type": "text", "fontSize": 9, "fontStyle": "italic", "color": "#999", "dy": 12},
          "encoding": {
            "x": {"field": "x", "type": "quantitative"},
            "y": {"field": "y", "type": "quantitative"},
            "text": {"field": "sub"},
            "align": {"condition": [{"test": "datum.x < 10", "value": "left"}], "value": "right"}
          }
        }
      ]
    }
  ]
}

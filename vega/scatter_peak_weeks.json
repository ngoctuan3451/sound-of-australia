{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 540,
  "title": {
    "text": "Long hits do not always reach number 1",
    "subtitle": "Top 15 ARIA singles by weeks on chart. Bar length = weeks; colour = best peak position.",
    "fontSize": 19,
    "subtitleFontSize": 12,
    "font": "Playfair Display",
    "subtitleColor": "#888",
    "anchor": "start"
  },
  "config": {"view": {"stroke": null}, "font": "Inter, system-ui, sans-serif"},
  "data": {"url": "https://raw.githubusercontent.com/ngoctuan3451/FIT2179/main/data/derived/aria_singles_summary.json"},
  "transform": [
    {"window": [{"op": "rank", "as": "wk_rank"}], "sort": [{"field": "weeks", "order": "descending"}]},
    {"filter": "datum.wk_rank <= 15"},
    {"calculate": "datum.artist + ' — ' + datum.title", "as": "label"},
    {"calculate": "'#' + datum.best", "as": "peak_label"},
    {"calculate": "datum.best == 1 ? 'Peaked at #1' : datum.best <= 5 ? 'Peaked in top 5' : datum.best <= 10 ? 'Peaked #6–10' : 'Peaked outside top 10'", "as": "peak_band"},
    {"calculate": "-datum.weeks", "as": "neg_weeks"}
  ],
  "layer": [
    {
      "mark": {"type": "bar", "cornerRadiusEnd": 4},
      "encoding": {
        "y": {
          "field": "label",
          "type": "nominal",
          "sort": {"field": "neg_weeks", "op": "min"},
          "title": null,
          "axis": {"labelFontSize": 12, "labelLimit": 230, "labelColor": "#333", "labelPadding": 8}
        },
        "x": {
          "field": "weeks",
          "type": "quantitative",
          "title": "Total weeks on the ARIA singles chart",
          "scale": {"domain": [0, 220]},
          "axis": {"grid": true, "gridOpacity": 0.15, "labelFontSize": 11, "titleFontSize": 11, "titleColor": "#666"}
        },
        "color": {
          "field": "peak_band",
          "type": "nominal",
          "scale": {
            "domain": ["Peaked at #1", "Peaked in top 5", "Peaked #6–10", "Peaked outside top 10"],
            "range":  ["#ff4f7b", "#a86300", "#00a99d", "#b8a9c9"]
          },
          "legend": {"orient": "bottom", "direction": "horizontal", "title": null, "labelFontSize": 11, "symbolSize": 160}
        },
        "tooltip": [
          {"field": "title",  "title": "Song"},
          {"field": "artist", "title": "Artist"},
          {"field": "weeks",  "title": "Weeks on chart"},
          {"field": "best",   "title": "Peak position"}
        ]
      }
    },
    {
      "mark": {"type": "text", "align": "left", "fontSize": 12, "fontWeight": 700, "color": "#17131f", "dx": 8},
      "encoding": {
        "y": {"field": "label", "type": "nominal", "sort": {"field": "neg_weeks", "op": "min"}},
        "x": {"field": "weeks", "type": "quantitative"},
        "text": {"field": "weeks"}
      }
    },
    {
      "mark": {"type": "text", "align": "right", "fontSize": 11, "fontWeight": 700, "color": "#17131f", "dx": -10},
      "encoding": {
        "y": {"field": "label", "type": "nominal", "sort": {"field": "neg_weeks", "op": "min"}},
        "x": {"field": "weeks", "type": "quantitative"},
        "text": {"field": "peak_label"}
      }
    },
    {
      "transform": [{"filter": "datum.artist == 'The Killers'"}],
      "mark": {"type": "text", "align": "left", "fontSize": 11, "fontWeight": 700, "fontStyle": "italic", "color": "#b92752", "dx": 36, "baseline": "middle"},
      "encoding": {
        "y": {"field": "label", "type": "nominal", "sort": {"field": "neg_weeks", "op": "min"}},
        "x": {"field": "weeks", "type": "quantitative"},
        "text": {"value": "← lowest peak in the top 15"}
      }
    },
    {
      "transform": [{"filter": "datum.artist == 'Glass Animals'"}],
      "mark": {"type": "text", "align": "left", "fontSize": 11, "fontWeight": 700, "fontStyle": "italic", "color": "#007c75", "dx": 36, "baseline": "middle", "lineBreak": "|", "lineHeight": 13},
      "encoding": {
        "y": {"field": "label", "type": "nominal", "sort": {"field": "neg_weeks", "op": "min"}},
        "x": {"field": "weeks", "type": "quantitative"},
        "text": {"value": "★ best of both:|#1 peak AND 159 weeks"}
      }
    }
  ]
}

{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 480,
  "title": {
    "text": "The Marathon Runners",
    "subtitle": "The 15 songs that spent the most weeks on the ARIA singles chart, with the colour of each bar showing the song's best ever position. Notice: hitting #1 isn't what keeps a song on the chart.",
    "fontSize": 16,
    "subtitleFontSize": 12,
    "font": "Playfair Display",
    "subtitleColor": "#888",
    "anchor": "start"
  },
  "config": {"view": {"stroke": null}, "font": "Inter, system-ui, sans-serif"},
  "data": {"url": "https://raw.githubusercontent.com/ngoctuan3451/FIT2179/main/data/derived/aria_singles_summary.json"},
  "transform": [
    {"calculate": "datum.artist + ' – ' + datum.title", "as": "label"},
    {"calculate": "datum.aus ? 'Australian' : 'International'", "as": "origin"},
    {"window": [{"op": "rank", "as": "wk_rank"}], "sort": [{"field": "weeks", "order": "descending"}]},
    {"filter": "datum.wk_rank <= 15"}
  ],
  "layer": [
    {
      "mark": {"type": "bar", "cornerRadiusEnd": 4, "height": {"band": 0.75}},
      "encoding": {
        "y": {
          "field": "label",
          "type": "nominal",
          "sort": {"field": "weeks", "order": "descending"},
          "title": null,
          "axis": {"labelFontSize": 12, "labelLimit": 320, "labelColor": "#333"}
        },
        "x": {
          "field": "weeks",
          "type": "quantitative",
          "title": "Weeks on the ARIA singles chart",
          "axis": {"grid": true, "gridOpacity": 0.15, "labelFontSize": 11, "titleFontSize": 11, "titleColor": "#666"}
        },
        "color": {
          "field": "best",
          "type": "quantitative",
          "scale": {"scheme": "yelloworangered", "reverse": true, "domain": [1, 30]},
          "legend": {
            "title": "Best position reached",
            "orient": "bottom-right",
            "gradientLength": 160,
            "titleFontSize": 11,
            "labelFontSize": 10,
            "format": "d"
          }
        },
        "tooltip": [
          {"field": "title",  "title": "Song"},
          {"field": "artist", "title": "Artist"},
          {"field": "origin", "title": "Origin"},
          {"field": "weeks",  "title": "Weeks on chart"},
          {"field": "best",   "title": "Best position"},
          {"field": "first",  "title": "First charted"}
        ]
      }
    },
    {
      "mark": {"type": "text", "align": "left", "fontSize": 11, "fontWeight": 600, "color": "#1a1a2e", "dx": 6},
      "encoding": {
        "y": {"field": "label", "type": "nominal", "sort": {"field": "weeks", "order": "descending"}},
        "x": {"field": "weeks", "type": "quantitative"},
        "text": {"field": "weeks"}
      }
    },
    {
      "mark": {"type": "text", "align": "right", "fontSize": 10, "fontWeight": 600, "color": "white", "dx": -8},
      "encoding": {
        "y": {"field": "label", "type": "nominal", "sort": {"field": "weeks", "order": "descending"}},
        "x": {"field": "weeks", "type": "quantitative"},
        "text": {"field": "best", "type": "quantitative", "format": "'#'d"}
      }
    }
  ]
}

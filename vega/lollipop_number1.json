{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 400,
  "title": {
    "text": "Australia's ARIA Singles Royalty",
    "subtitle": "Top 15 Australian artists by total weeks on the ARIA singles chart",
    "fontSize": 16,
    "subtitleFontSize": 12,
    "font": "Playfair Display",
    "subtitleColor": "#888",
    "anchor": "start"
  },
  "config": {"view": {"stroke": null}, "font": "Inter, system-ui, sans-serif"},
  "data": {"url": "https://raw.githubusercontent.com/ngoctuan3451/FIT2179/main/data/derived/aria_top_singles_artists.json"},
  "layer": [
    {
      "mark": {"type": "rule", "color": "#f39c12", "strokeWidth": 2.5},
      "encoding": {
        "y": {
          "field": "artist",
          "type": "nominal",
          "sort": "-x",
          "title": null,
          "axis": {"labelFontSize": 12, "labelLimit": 220, "labelColor": "#333"}
        },
        "x": {
          "field": "weeks",
          "type": "quantitative",
          "title": "Total weeks on chart",
          "axis": {"grid": true, "gridOpacity": 0.15, "labelFontSize": 11, "titleFontSize": 11, "titleColor": "#666"}
        },
        "x2": {"datum": 0}
      }
    },
    {
      "mark": {"type": "circle", "color": "#d35400", "size": 280, "stroke": "white", "strokeWidth": 2.5},
      "encoding": {
        "y": {"field": "artist", "type": "nominal", "sort": "-x"},
        "x": {"field": "weeks", "type": "quantitative"},
        "tooltip": [
          {"field": "artist", "title": "Artist"},
          {"field": "weeks", "title": "Weeks on chart"}
        ]
      }
    },
    {
      "mark": {"type": "text", "align": "left", "fontSize": 11, "fontWeight": 600, "color": "#333", "dx": 12},
      "encoding": {
        "y": {"field": "artist", "type": "nominal", "sort": "-x"},
        "x": {"field": "weeks", "type": "quantitative"},
        "text": {"field": "weeks"}
      }
    },
    {
      "transform": [
        {"window": [{"op": "rank", "as": "lead"}], "sort": [{"field": "weeks", "order": "descending"}]},
        {"filter": "datum.lead == 1"}
      ],
      "mark": {"type": "text", "align": "left", "fontSize": 10, "fontWeight": 700, "fontStyle": "italic", "color": "#c0392b", "dx": 38, "dy": -2},
      "encoding": {
        "y": {"field": "artist", "type": "nominal", "sort": "-x"},
        "x": {"field": "weeks", "type": "quantitative"},
        "text": {"value": "★ +60% over #2"}
      }
    }
  ]
}

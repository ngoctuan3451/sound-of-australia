{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 340,
  "title": {
    "text": "The Rise of Australian Music on the ARIA Charts",
    "subtitle": "% of ARIA Top 50 singles by Australian artists, by year.",
    "fontSize": 16,
    "subtitleFontSize": 12,
    "font": "Playfair Display",
    "subtitleColor": "#888",
    "anchor": "start"
  },
  "config": {"view": {"stroke": null}, "font": "Inter, system-ui, sans-serif"},
  "data": {"url": "https://raw.githubusercontent.com/ngoctuan3451/FIT2179/main/data/derived/aria_singles_yearly.json"},
  "transform": [{"filter": "datum.year >= 2015"}],
  "layer": [
    {
      "mark": {"type": "area", "line": {"strokeWidth": 3, "color": "#f39c12"}, "color": "#f39c12", "fillOpacity": 0.25, "interpolate": "monotone"},
      "encoding": {
        "x": {"field": "year", "type": "quantitative", "title": null, "axis": {"grid": false, "labelFontSize": 11, "format": "d"}},
        "y": {"field": "aus_pct", "type": "quantitative", "title": "% Australian songs", "axis": {"grid": true, "gridOpacity": 0.15, "labelFontSize": 11, "titleFontSize": 11, "titleColor": "#666"}, "scale": {"domain": [0, 15]}},
        "tooltip": [
          {"field": "year", "title": "Year"},
          {"field": "aus_pct", "title": "% Aussie", "format": ".1f"},
          {"field": "aus", "title": "Aussie entries"},
          {"field": "total", "title": "Total entries"}
        ]
      }
    },
    {
      "mark": {"type": "point", "filled": true, "size": 90, "color": "#d35400", "stroke": "white", "strokeWidth": 2},
      "encoding": {
        "x": {"field": "year", "type": "quantitative"},
        "y": {"field": "aus_pct", "type": "quantitative"}
      }
    },
    {
      "mark": {"type": "rule", "color": "#888", "strokeDash": [4, 4], "strokeWidth": 1},
      "encoding": {"y": {"datum": 8.4}}
    },
    {
      "mark": {"type": "text", "align": "right", "fontSize": 9, "color": "#999", "fontStyle": "italic", "dx": -4, "dy": -4},
      "encoding": {
        "x": {"datum": 2025},
        "y": {"datum": 8.4},
        "text": {"value": "8.4% avg"}
      }
    },
    {
      "mark": {"type": "text", "align": "center", "fontSize": 10, "fontStyle": "italic", "color": "#c0392b"},
      "encoding": {
        "x": {"datum": 2020},
        "y": {"datum": 14.5},
        "text": {"value": "Tones and I era"}
      }
    }
  ]
}

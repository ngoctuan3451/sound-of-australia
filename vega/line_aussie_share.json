{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 350,
  "title": {
    "text": "The Rise of Australian Music on the ARIA Charts",
    "subtitle": "Share of Top 50 ARIA singles by Australian artists — the streaming era changed everything",
    "fontSize": 18,
    "subtitleFontSize": 12,
    "font": "Playfair Display",
    "subtitleColor": "#888",
    "anchor": "start"
  },
  "data": {
    "url": "https://raw.githubusercontent.com/ngoctuan3451/FIT2179/main/data/single_charts.csv"
  },
  "transform": [
    {
      "calculate": "datum.aus_flag == 'TRUE' || datum.aus_flag == 'True' || datum.aus_flag == true ? 1 : 0",
      "as": "is_aussie"
    },
    {
      "timeUnit": "year",
      "field": "chart_date",
      "as": "year"
    },
    {
      "aggregate": [
        {"op": "count", "as": "total"},
        {"op": "sum", "field": "is_aussie", "as": "aus_count"}
      ],
      "groupby": ["year"]
    },
    {
      "calculate": "datum.aus_count / datum.total * 100",
      "as": "aus_pct"
    },
    {"filter": "year(datum.year) >= 2015"}
  ],
  "layer": [
    {
      "mark": {
        "type": "area",
        "line": {"strokeWidth": 3, "color": "#f39c12"},
        "color": "#f39c12",
        "fillOpacity": 0.25,
        "interpolate": "monotone"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "temporal",
          "title": null,
          "axis": {"grid": false, "labelFontSize": 11, "format": "%Y"}
        },
        "y": {
          "field": "aus_pct",
          "type": "quantitative",
          "title": "% Australian Songs",
          "axis": {"grid": true, "gridOpacity": 0.2, "labelFontSize": 11},
          "scale": {"domain": [0, 15]}
        },
        "tooltip": [
          {"field": "year", "type": "temporal", "title": "Year", "format": "%Y"},
          {"field": "aus_pct", "type": "quantitative", "title": "% Aussie Songs", "format": ".1f"},
          {"field": "aus_count", "type": "quantitative", "title": "Aussie Entries"},
          {"field": "total", "type": "quantitative", "title": "Total Entries"}
        ]
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 80,
        "color": "#d35400",
        "stroke": "white",
        "strokeWidth": 2
      },
      "encoding": {
        "x": {"field": "year", "type": "temporal"},
        "y": {"field": "aus_pct", "type": "quantitative"},
        "tooltip": [
          {"field": "year", "type": "temporal", "title": "Year", "format": "%Y"},
          {"field": "aus_pct", "type": "quantitative", "title": "% Aussie Songs", "format": ".1f"}
        ]
      }
    },
    {
      "mark": {
        "type": "rule",
        "color": "#888",
        "strokeDash": [4, 4],
        "strokeWidth": 1
      },
      "encoding": {
        "y": {"datum": 8.4}
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "right",
        "fontSize": 10,
        "color": "#888",
        "fontStyle": "italic",
        "dx": -5,
        "dy": -5
      },
      "encoding": {
        "x": {"datum": {"year": 2025}, "type": "temporal"},
        "y": {"datum": 8.4},
        "text": {"value": "8.4% all-time avg"}
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "center",
        "fontSize": 12,
        "fontWeight": 600,
        "color": "#c0392b",
        "dy": -20
      },
      "encoding": {
        "x": {"datum": {"year": 2021}, "type": "temporal"},
        "y": {"datum": 13, "type": "quantitative"},
        "text": {"value": "Peak: Tones and I era"}
      }
    }
  ]
}
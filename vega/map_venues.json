{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 520,
  "title": {
    "text": "Live Music Venues Across Melbourne",
    "subtitle": "227 registered venues — bars dominate, but performance spaces anchor the serious music scene",
    "fontSize": 18,
    "subtitleFontSize": 12,
    "font": "Playfair Display",
    "subtitleColor": "#888",
    "anchor": "start"
  },
  "projection": {
    "type": "mercator",
    "center": [144.968, -37.812],
    "scale": 400000
  },
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/FIT3179/Vega-Lite/main/6_advanced_examples/data/VIC_LOCALITY_POLYGON_SHP.json",
        "format": {
          "type": "topojson",
          "feature": "VIC_LOCALITY_POLYGON_SHP"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#f7f4f0",
        "stroke": "#333",
        "strokeWidth": 1.0
      }
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/ngoctuan3451/FIT2179/main/data/live-music-venues.csv"
      },
      "transform": [
        {
          "calculate": "datum.space_type == 'Bar' || datum.space_type == 'bar' ? 'Bar' : datum.space_type == 'Nightclub' ? 'Nightclub' : datum.space_type == 'Hotel' ? 'Hotel' : datum.space_type == 'Venue' ? 'Venue' : datum.space_type == 'Performance space' ? 'Performance space' : 'Other'",
          "as": "Venue Type"
        }
      ],
      "mark": {
        "type": "circle",
        "opacity": 0.8,
        "stroke": "white",
        "strokeWidth": 0.8,
        "size": 45
      },
      "encoding": {
        "longitude": {"field": "lon", "type": "quantitative"},
        "latitude": {"field": "lat", "type": "quantitative"},
        "color": {
          "field": "Venue Type",
          "type": "nominal",
          "title": "Venue Type",
          "scale": {
  "domain": ["Bar", "Nightclub", "Hotel", "Venue", "Performance space", "Other"],
  "range": ["#E63946", "#B100CD", "#0077FF", "#00C853", "#FF8C00", "#999999"]
},
          "legend": {
            "orient": "right",
            "labelFontSize": 12,
            "symbolSize": 100,
            "title": "Venue Type",
            "titleFontSize": 12,
            "titleFontWeight": 600
          }
        },
        "tooltip": [
          {"field": "venue_name", "title": "📍 Venue"},
          {"field": "Venue Type", "title": "Type"},
          {"field": "venue_address", "title": "Address"}
        ]
      }
    },
    {
      "data": {
        "values": [
          {"suburb": "Melbourne CBD", "lon": 144.9631, "lat": -37.8150},
          {"suburb": "Fitzroy", "lon": 144.978, "lat": -37.797},
          {"suburb": "Carlton", "lon": 144.962, "lat": -37.803},
          {"suburb": "Collingwood", "lon": 144.991, "lat": -37.805},
          {"suburb": "Richmond", "lon": 145.001, "lat": -37.827},
          {"suburb": "South Yarra", "lon": 144.993, "lat": -37.843},
          {"suburb": "Docklands", "lon": 144.942, "lat": -37.818},
          {"suburb": "North Melbourne", "lon": 144.950, "lat": -37.799},
          {"suburb": "Southbank", "lon": 144.963, "lat": -37.824}
        ]
      },
      "layer": [
        {
          "mark": {
            "type": "text",
            "fontSize": 10,
            "fontWeight": 700,
            "stroke": "white",
            "strokeWidth": 3
          },
          "encoding": {
            "longitude": {"field": "lon", "type": "quantitative"},
            "latitude": {"field": "lat", "type": "quantitative"},
            "text": {"field": "suburb", "type": "nominal"},
            "color": {"value": "#222"}
          }
        },
        {
          "mark": {
            "type": "text",
            "fontSize": 10,
            "fontWeight": 700
          },
          "encoding": {
            "longitude": {"field": "lon", "type": "quantitative"},
            "latitude": {"field": "lat", "type": "quantitative"},
            "text": {"field": "suburb", "type": "nominal"},
            "color": {"value": "#222"}
          }
        }
      ]
    }
  ]
}
{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Where Melbourne's Live Music Happens",
    "subtitle": "Each hexagon covers roughly 500 metres. Darker hexes pack more registered live-music venues. Source: City of Melbourne Open Data (2024).",
    "fontSize": 19,
    "subtitleFontSize": 12,
    "font": "Playfair Display",
    "subtitleColor": "#888",
    "anchor": "start",
    "offset": 16
  },
  "config": {
    "view": {"stroke": null},
    "font": "Inter, system-ui, sans-serif"
  },
  "width": "container",
  "height": 500,
  "projection": {
    "type": "mercator",
    "center": [144.972, -37.815],
    "scale": 280000
  },
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/FIT3179/Vega-Lite/main/6_advanced_examples/data/VIC_LOCALITY_POLYGON_SHP.json",
        "format": {"type": "topojson", "feature": "VIC_LOCALITY_POLYGON_SHP"}
      },
      "mark": {"type": "geoshape", "fill": "#f7f4ef", "stroke": "#d8d3c8", "strokeWidth": 0.8}
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/ngoctuan3451/FIT2179/main/data/live-music-venues.csv",
        "format": {"type": "csv", "parse": {"lat": "number", "lon": "number"}}
      },
      "transform": [
        {"filter": "isValid(datum.lat) && isValid(datum.lon)"},
        {"calculate": "round((datum.lon - 144.93) * 120)",  "as": "bx"},
        {"calculate": "round((datum.lat + 37.86) * 220)",   "as": "by"},
        {"aggregate": [{"op": "count", "as": "venues"}], "groupby": ["bx", "by"]},
        {"calculate": "datum.bx / 120 + 144.93 + ((datum.by % 2 + 2) % 2 == 0 ? 0 : 0.004167)", "as": "lon"},
        {"calculate": "datum.by / 220 - 37.86", "as": "lat"}
      ],
      "mark": {
        "type": "point",
        "shape": "M 0,-1 L 0.866,-0.5 L 0.866,0.5 L 0,1 L -0.866,0.5 L -0.866,-0.5 Z",
        "filled": true,
        "stroke": "#fff",
        "strokeWidth": 1.8,
        "size": 1700,
        "opacity": 0.95
      },
      "encoding": {
        "longitude": {"field": "lon", "type": "quantitative"},
        "latitude":  {"field": "lat", "type": "quantitative"},
        "color": {
          "field": "venues",
          "type": "quantitative",
          "scale": {"scheme": "yelloworangered", "domainMin": 1},
          "legend": {
            "title": "Venues per hex",
            "orient": "bottom-right",
            "gradientLength": 160,
            "titleFontSize": 11,
            "labelFontSize": 10,
            "format": "d"
          }
        },
        "tooltip": [
          {"field": "venues", "type": "quantitative", "title": "Venues in this hex"}
        ]
      }
    },
    {
      "data": {
        "values": [
          {"suburb": "CBD",            "lon": 144.9631, "lat": -37.815},
          {"suburb": "Fitzroy",        "lon": 144.978,  "lat": -37.797},
          {"suburb": "Carlton",        "lon": 144.964,  "lat": -37.800},
          {"suburb": "Collingwood",    "lon": 144.989,  "lat": -37.802},
          {"suburb": "Richmond",       "lon": 145.001,  "lat": -37.826},
          {"suburb": "South Yarra",    "lon": 144.993,  "lat": -37.840},
          {"suburb": "Docklands",      "lon": 144.942,  "lat": -37.818},
          {"suburb": "North Melbourne","lon": 144.948,  "lat": -37.799},
          {"suburb": "Southbank",      "lon": 144.963,  "lat": -37.824}
        ]
      },
      "layer": [
        {
          "mark": {
            "type": "text",
            "fontSize": 11,
            "fontWeight": 700,
            "stroke": "white",
            "strokeWidth": 3
          },
          "encoding": {
            "longitude": {"field": "lon", "type": "quantitative"},
            "latitude":  {"field": "lat", "type": "quantitative"},
            "text": {"field": "suburb"}
          }
        },
        {
          "mark": {"type": "text", "fontSize": 11, "fontWeight": 700, "color": "#222"},
          "encoding": {
            "longitude": {"field": "lon", "type": "quantitative"},
            "latitude":  {"field": "lat", "type": "quantitative"},
            "text": {"field": "suburb"}
          }
        }
      ]
    },
    {
      "data": {"values": [{"lon": 144.966, "lat": -37.815}]},
      "mark": {"type": "rule", "color": "#7a1a06", "strokeWidth": 1.4},
      "encoding": {
        "longitude":  {"field": "lon", "type": "quantitative"},
        "latitude":   {"field": "lat", "type": "quantitative"},
        "longitude2": {"datum": 144.998},
        "latitude2":  {"datum": -37.806}
      }
    },
    {
      "data": {"values": [{"lon": 144.998, "lat": -37.806}]},
      "mark": {"type": "text", "fontSize": 12, "fontWeight": 700, "color": "#7a1a06", "align": "left", "dx": 6, "dy": -4},
      "encoding": {
        "longitude": {"field": "lon", "type": "quantitative"},
        "latitude":  {"field": "lat", "type": "quantitative"},
        "text": {"value": "31 venues in this hex"}
      }
    },
    {
      "data": {"values": [{"lon": 144.998, "lat": -37.806}]},
      "mark": {"type": "text", "fontSize": 10, "fontStyle": "italic", "color": "#7a1a06", "align": "left", "dx": 6, "dy": 10},
      "encoding": {
        "longitude": {"field": "lon", "type": "quantitative"},
        "latitude":  {"field": "lat", "type": "quantitative"},
        "text": {"value": "densest live-music block — at the CBD"}
      }
    }
  ]
}

{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Live Music Venues Across Melbourne",
    "subtitle": "227 registered venues — bars dominate, but performance spaces anchor the serious music scene",
    "fontSize": 18,
    "subtitleFontSize": 12,
    "font": "Playfair Display",
    "subtitleColor": "#888",
    "anchor": "start"
  },
  "config": {"view": {"stroke": null}},
  "hconcat": [
    {
      "width": 620,
      "height": 520,
      "projection": {
        "type": "mercator",
        "center": [144.968, -37.812],
        "scale": 200000
      },
      "layer": [
        {
          "data": {
            "url": "https://raw.githubusercontent.com/FIT3179/Vega-Lite/main/6_advanced_examples/data/VIC_LOCALITY_POLYGON_SHP.json",
            "format": {
              "type": "topojson",
              "feature": "VIC_LOCALITY_POLYGON_SHP"
            }
          },
          "mark": {
            "type": "geoshape",
            "fill": "#f7f4f0",
            "stroke": "#333",
            "strokeWidth": 1.0
          }
        },
        {
          "data": {
            "url": "https://raw.githubusercontent.com/ngoctuan3451/FIT2179/main/data/live-music-venues.csv"
          },
          "transform": [
            {
              "calculate": "datum.space_type == 'Bar' || datum.space_type == 'bar' ? 'Bar' : datum.space_type == 'Nightclub' ? 'Nightclub' : datum.space_type == 'Hotel' ? 'Hotel' : datum.space_type == 'Venue' ? 'Venue' : datum.space_type == 'Performance space' ? 'Performance space' : 'Other'",
              "as": "Venue Type"
            },
            {
              "calculate": "datum.lon + (random() - 0.5) * 0.002",
              "as": "lon_jitter"
            },
            {
              "calculate": "datum.lat + (random() - 0.5) * 0.002",
              "as": "lat_jitter"
            }
          ],
          "params": [
            {
              "name": "venue_select",
              "select": {
                "type": "point",
                "fields": ["Venue Type"]
              },
              "bind": "legend"
            }
          ],
          "mark": {
            "type": "circle",
            "stroke": "white",
            "strokeWidth": 0.8,
            "size": 40
          },
          "encoding": {
            "longitude": {"field": "lon_jitter", "type": "quantitative"},
            "latitude": {"field": "lat_jitter", "type": "quantitative"},
            "color": {
              "field": "Venue Type",
              "type": "nominal",
              "scale": {
                "domain": ["Bar", "Nightclub", "Hotel", "Venue", "Performance space", "Other"],
                "range": ["#E63946", "#B100CD", "#0077FF", "#00C853", "#FF8C00", "#999999"]
              },
              "legend": {
                "orient": "bottom",
                "labelFontSize": 11,
                "symbolSize": 100,
                "title": null,
                "columns": 3
              }
            },
            "opacity": {
              "condition": {"param": "venue_select", "value": 0.85, "empty": true},
              "value": 0.1
            },
            "tooltip": [
              {"field": "venue_name", "title": "📍 Venue"},
              {"field": "Venue Type", "title": "Type"},
              {"field": "venue_address", "title": "Address"}
            ]
          }
        },
        {
          "data": {
            "values": [
              {"suburb": "Melbourne CBD", "lon": 144.9631, "lat": -37.815},
              {"suburb": "Fitzroy", "lon": 144.978, "lat": -37.797},
              {"suburb": "Carlton", "lon": 144.962, "lat": -37.803},
              {"suburb": "Collingwood", "lon": 144.991, "lat": -37.805},
              {"suburb": "Richmond", "lon": 145.001, "lat": -37.827},
              {"suburb": "South Yarra", "lon": 144.993, "lat": -37.843},
              {"suburb": "Docklands", "lon": 144.942, "lat": -37.818},
              {"suburb": "North Melbourne", "lon": 144.950, "lat": -37.799},
              {"suburb": "Southbank", "lon": 144.963, "lat": -37.824}
            ]
          },
          "layer": [
            {
              "mark": {
                "type": "text",
                "fontSize": 10,
                "fontWeight": 700,
                "stroke": "white",
                "strokeWidth": 3
              },
              "encoding": {
                "longitude": {"field": "lon", "type": "quantitative"},
                "latitude": {"field": "lat", "type": "quantitative"},
                "text": {"field": "suburb", "type": "nominal"},
                "color": {"value": "#222"}
              }
            },
            {
              "mark": {
                "type": "text",
                "fontSize": 10,
                "fontWeight": 700
              },
              "encoding": {
                "longitude": {"field": "lon", "type": "quantitative"},
                "latitude": {"field": "lat", "type": "quantitative"},
                "text": {"field": "suburb", "type": "nominal"},
                "color": {"value": "#222"}
              }
            }
          ]
        }
      ]
    },
    {
      "width": 220,
      "height": 520,
      "data": {
        "url": "https://raw.githubusercontent.com/ngoctuan3451/FIT2179/main/data/live-music-venues.csv"
      },
      "transform": [
        {
          "calculate": "datum.space_type == 'Bar' || datum.space_type == 'bar' ? 'Bar' : datum.space_type == 'Nightclub' ? 'Nightclub' : datum.space_type == 'Hotel' ? 'Hotel' : datum.space_type == 'Venue' ? 'Venue' : datum.space_type == 'Performance space' ? 'Performance space' : 'Other'",
          "as": "Venue Type"
        },
        {
          "aggregate": [{"op": "count", "as": "count"}],
          "groupby": ["Venue Type"]
        }
      ],
      "layer": [
        {
          "mark": {
            "type": "bar",
            "cornerRadiusEnd": 4
          },
          "encoding": {
            "y": {
              "field": "Venue Type",
              "type": "nominal",
              "sort": "-x",
              "title": null,
              "axis": {"labelFontSize": 12, "labelColor": "#333"}
            },
            "x": {
              "field": "count",
              "type": "quantitative",
              "title": "Number of Venues",
              "axis": {"grid": false, "labelFontSize": 11}
            },
            "color": {
              "field": "Venue Type",
              "type": "nominal",
              "scale": {
                "domain": ["Bar", "Nightclub", "Hotel", "Venue", "Performance space", "Other"],
                "range": ["#E63946", "#B100CD", "#0077FF", "#00C853", "#FF8C00", "#999999"]
              },
              "legend": null
            },
            "opacity": {
              "condition": {"param": "venue_select", "value": 1, "empty": true},
              "value": 0.2
            },
            "tooltip": [
              {"field": "Venue Type", "title": "Type"},
              {"field": "count", "title": "Total Venues"}
            ]
          }
        },
        {
          "mark": {
            "type": "text",
            "align": "left",
            "dx": 5,
            "fontSize": 12,
            "fontWeight": 600,
            "color": "#333"
          },
          "encoding": {
            "y": {"field": "Venue Type", "type": "nominal", "sort": "-x"},
            "x": {"field": "count", "type": "quantitative"},
            "text": {"field": "count", "type": "quantitative"},
            "opacity": {
              "condition": {"param": "venue_select", "value": 1, "empty": true},
              "value": 0.2
            }
          }
        }
      ]
    }
  ]
}
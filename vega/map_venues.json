{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "227 live-music venues across Melbourne",
    "subtitle": "Each dot is one registered venue, coloured by venue type. The scene clusters along the CBD spine and the Fitzroy / Collingwood corridor.",
    "fontSize": 19,
    "subtitleFontSize": 12,
    "font": "Playfair Display",
    "subtitleColor": "#888",
    "anchor": "start",
    "offset": 16
  },
  "config": {
    "view": {"stroke": null},
    "font": "Inter, system-ui, sans-serif"
  },
  "width": "container",
  "height": 500,
  "projection": {
    "type": "mercator",
    "center": [144.962, -37.812],
    "scale": 290000
  },
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/FIT3179/Vega-Lite/main/6_advanced_examples/data/VIC_LOCALITY_POLYGON_SHP.json",
        "format": {"type": "topojson", "feature": "VIC_LOCALITY_POLYGON_SHP"}
      },
      "mark": {"type": "geoshape", "fill": "#f7f4ef", "stroke": "#d8d3c8", "strokeWidth": 0.8}
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/ngoctuan3451/FIT2179/main/data/live-music-venues.csv",
        "format": {"type": "csv", "parse": {"lat": "number", "lon": "number"}}
      },
      "transform": [
        {"filter": "isValid(datum.lat) && isValid(datum.lon)"},
        {"calculate": "datum.space_type == null || datum.space_type == '' ? 'Other' : datum.space_type == 'bar' ? 'Bar' : datum.space_type", "as": "type"},
        {"calculate": "indexof(['Bar','Hotel','Nightclub','Performance space','Theatre','Venue'], datum.type) >= 0 ? datum.type : 'Other'", "as": "type_group"}
      ],
      "mark": {
        "type": "circle",
        "filled": true,
        "stroke": "white",
        "strokeWidth": 0.7,
        "size": 90,
        "opacity": 0.92
      },
      "encoding": {
        "longitude": {"field": "lon", "type": "quantitative"},
        "latitude":  {"field": "lat", "type": "quantitative"},
        "color": {
          "field": "type_group",
          "type": "nominal",
          "scale": {
            "domain": ["Bar", "Hotel", "Nightclub", "Performance space", "Theatre", "Venue", "Other"],
            "range":  ["#c0392b", "#e67e22", "#8e44ad", "#16a085", "#2980b9", "#27ae60", "#7f8c8d"]
          },
          "legend": {
            "title": "Venue type",
            "orient": "bottom",
            "direction": "horizontal",
            "labelFontSize": 12,
            "titleFontSize": 11,
            "symbolSize": 160,
            "columns": 0,
            "columnPadding": 16
          }
        },
        "tooltip": [
          {"field": "venue_name",   "title": "Venue"},
          {"field": "type",         "title": "Type"},
          {"field": "venue_address","title": "Address"}
        ]
      }
    },
    {
      "data": {
        "values": [
          {"suburb": "CBD",            "lon": 144.9631, "lat": -37.815},
          {"suburb": "Fitzroy",        "lon": 144.978,  "lat": -37.797},
          {"suburb": "Carlton",        "lon": 144.964,  "lat": -37.800},
          {"suburb": "Collingwood",    "lon": 144.989,  "lat": -37.802},
          {"suburb": "Richmond",       "lon": 145.001,  "lat": -37.826},
          {"suburb": "South Yarra",    "lon": 144.993,  "lat": -37.840},
          {"suburb": "Docklands",      "lon": 144.942,  "lat": -37.818},
          {"suburb": "North Melbourne","lon": 144.948,  "lat": -37.799},
          {"suburb": "Southbank",      "lon": 144.963,  "lat": -37.824}
        ]
      },
      "layer": [
        {
          "mark": {"type": "text", "fontSize": 11, "fontWeight": 700, "stroke": "white", "strokeWidth": 3},
          "encoding": {
            "longitude": {"field": "lon", "type": "quantitative"},
            "latitude":  {"field": "lat", "type": "quantitative"},
            "text": {"field": "suburb"}
          }
        },
        {
          "mark": {"type": "text", "fontSize": 11, "fontWeight": 700, "color": "#222"},
          "encoding": {
            "longitude": {"field": "lon", "type": "quantitative"},
            "latitude":  {"field": "lat", "type": "quantitative"},
            "text": {"field": "suburb"}
          }
        }
      ]
    },
    {
      "data": {"values": [{"lon": 145.008, "lat": -37.812}]},
      "mark": {"type": "text", "fontSize": 12.5, "fontWeight": 700, "fontStyle": "italic", "color": "#c0392b", "align": "left", "lineBreak": "|", "lineHeight": 15, "stroke": "white", "strokeWidth": 3},
      "encoding": {
        "longitude": {"field": "lon", "type": "quantitative"},
        "latitude":  {"field": "lat", "type": "quantitative"},
        "text": {"value": "Busiest live-music hub:|the dense CBD core"}
      }
    },
    {
      "data": {"values": [{"lon": 145.008, "lat": -37.812}]},
      "mark": {"type": "text", "fontSize": 12.5, "fontWeight": 700, "fontStyle": "italic", "color": "#c0392b", "align": "left", "lineBreak": "|", "lineHeight": 15},
      "encoding": {
        "longitude": {"field": "lon", "type": "quantitative"},
        "latitude":  {"field": "lat", "type": "quantitative"},
        "text": {"value": "Busiest live-music hub:|the dense CBD core"}
      }
    },
    {
      "data": {"values": [{"x": 145.005, "y": -37.813, "x2": 144.9658, "y2": -37.8185}]},
      "mark": {"type": "rule", "color": "#c0392b", "strokeWidth": 2},
      "encoding": {
        "longitude":  {"field": "x",  "type": "quantitative"},
        "latitude":   {"field": "y",  "type": "quantitative"},
        "longitude2": {"field": "x2"},
        "latitude2":  {"field": "y2"}
      }
    }
  ]
}

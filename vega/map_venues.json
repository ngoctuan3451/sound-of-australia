{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 500,
  "title": {
    "text": "Live Music Venues Across Melbourne",
    "subtitle": "227 registered venues — filter by type to explore the scene",
    "fontSize": 18,
    "subtitleFontSize": 12,
    "font": "Playfair Display",
    "subtitleColor": "#888",
    "anchor": "start"
  },
  "projection": {
    "type": "mercator",
    "center": [144.963, -37.812],
    "scale": 180000
  },
  "params": [
    {
      "name": "venue_type",
      "bind": {
        "input": "select",
        "options": [
          null, "Bar", "Nightclub", "Hotel",
          "Venue", "Performance space",
          "Theatre", "Multi-use", "Museum", "Library"
        ],
        "labels": [
          "Show All", "Bar", "Nightclub", "Hotel",
          "Venue", "Performance space",
          "Theatre", "Multi-use", "Museum", "Library"
        ],
        "name": "Filter by venue type: "
      }
    }
  ],
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/FIT3179/Vega-Lite/main/6_advanced_examples/data/VIC_LOCALITY_POLYGON_SHP.json",
        "format": {
          "type": "topojson",
          "feature": "VIC_LOCALITY_POLYGON_SHP"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#f0ede8",
        "stroke": "#ccc",
        "strokeWidth": 0.6
      }
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/ngoctuan3451/FIT2179/main/data/live-music-venues.csv"
      },
      "transform": [
        {
          "calculate": "datum.space_type == 'bar' ? 'Bar' : (datum.space_type == null || datum.space_type == '' ? 'Other' : datum.space_type)",
          "as": "Venue Type"
        },
        {
          "filter": "venue_type == null || datum['Venue Type'] == venue_type"
        }
      ],
      "mark": {
        "type": "circle",
        "opacity": 0.85,
        "stroke": "white",
        "strokeWidth": 0.8
      },
      "encoding": {
        "longitude": {"field": "lon", "type": "quantitative"},
        "latitude": {"field": "lat", "type": "quantitative"},
        "color": {
          "field": "Venue Type",
          "type": "nominal",
          "title": "Venue Type",
          "scale": {"scheme": "tableau10"}
        },
        "size": {"value": 90},
        "tooltip": [
          {"field": "venue_name", "title": "Venue"},
          {"field": "Venue Type", "title": "Type"},
          {"field": "venue_address", "title": "Address"},
          {"field": "website", "title": "Website"}
        ]
      }
    },
    {
      "data": {
        "values": [
          {"suburb": "Melbourne CBD", "lon": 144.963, "lat": -37.814},
          {"suburb": "Fitzroy", "lon": 144.978, "lat": -37.797},
          {"suburb": "Carlton", "lon": 144.966, "lat": -37.799},
          {"suburb": "Collingwood", "lon": 144.987, "lat": -37.803},
          {"suburb": "Richmond", "lon": 144.999, "lat": -37.824},
          {"suburb": "South Yarra", "lon": 144.993, "lat": -37.841},
          {"suburb": "Docklands", "lon": 144.944, "lat": -37.816},
          {"suburb": "North Melbourne", "lon": 144.953, "lat": -37.796}
        ]
      },
      "mark": {
        "type": "text",
        "fontSize": 11,
        "color": "#444",
        "fontStyle": "italic",
        "fontWeight": 600,
        "dy": -8
      },
      "encoding": {
        "longitude": {"field": "lon", "type": "quantitative"},
        "latitude": {"field": "lat", "type": "quantitative"},
        "text": {"field": "suburb", "type": "nominal"}
      }
    }
  ]
}
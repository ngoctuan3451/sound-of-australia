{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 440,
  "title": {
    "text": "Every Time an Australian Topped the Album Chart",
    "subtitle": "Each circle is one Australian album that hit #1 on the ARIA charts (1988–2025). Bigger circle = more weeks spent at #1. The biggest dots are the records that defined their decade.",
    "fontSize": 16,
    "subtitleFontSize": 12,
    "font": "Playfair Display",
    "subtitleColor": "#888",
    "anchor": "start"
  },
  "config": {"view": {"stroke": null}, "font": "Inter, system-ui, sans-serif"},
  "data": {"url": "https://raw.githubusercontent.com/ngoctuan3451/FIT2179/main/data/derived/aus_n1_albums_timeline.json"},
  "layer": [
    {
      "mark": {"type": "circle", "filled": true, "opacity": 0.75, "stroke": "#fff", "strokeWidth": 1.2},
      "encoding": {
        "x": {
          "field": "year",
          "type": "quantitative",
          "title": null,
          "scale": {"domain": [1987, 2026]},
          "axis": {"format": "d", "grid": false, "labelFontSize": 11, "labelColor": "#555", "tickCount": 10}
        },
        "y": {
          "field": "weeks_at_1",
          "type": "quantitative",
          "title": "Weeks spent at #1",
          "scale": {"domain": [0, 32]},
          "axis": {"grid": true, "gridOpacity": 0.15, "labelFontSize": 11, "titleFontSize": 11, "titleColor": "#666"}
        },
        "size": {
          "field": "weeks_at_1",
          "type": "quantitative",
          "scale": {"range": [40, 1200]},
          "legend": null
        },
        "color": {
          "field": "weeks_at_1",
          "type": "quantitative",
          "scale": {"scheme": "oranges", "domainMin": 1},
          "legend": null
        },
        "tooltip": [
          {"field": "artist", "title": "Artist"},
          {"field": "title",  "title": "Album"},
          {"field": "year",   "title": "Year"},
          {"field": "weeks_at_1", "title": "Weeks at #1"}
        ]
      }
    },
    {
      "transform": [{"filter": "datum.weeks_at_1 >= 5"}],
      "mark": {"type": "text", "align": "left", "fontSize": 10, "fontWeight": 600, "color": "#1a1a2e", "dx": 10, "dy": -2},
      "encoding": {
        "x": {"field": "year", "type": "quantitative"},
        "y": {"field": "weeks_at_1", "type": "quantitative"},
        "text": {"field": "title"}
      }
    },
    {
      "data": {"values": [
        {"x": 1994, "y": 28, "t": "267 Australian albums have reached #1"},
        {"x": 1994, "y": 26, "t": "since 1988 — across pop, rock, country and Idol-era pop."}
      ]},
      "mark": {"type": "text", "align": "left", "fontSize": 11, "fontStyle": "italic", "color": "#555"},
      "encoding": {
        "x": {"field": "x", "type": "quantitative"},
        "y": {"field": "y", "type": "quantitative"},
        "text": {"field": "t"}
      }
    }
  ]
}

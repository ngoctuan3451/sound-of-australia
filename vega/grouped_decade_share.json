{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 380,
  "title": {
    "text": "Aussies own the album chart — but almost never the singles chart",
    "subtitle": "For each decade, the BLUE bar is the Australian share of the ARIA albums chart. The ORANGE bar is the same for singles. The orange bar barely existed until the 2020s.",
    "fontSize": 16,
    "subtitleFontSize": 12,
    "font": "Playfair Display",
    "subtitleColor": "#888",
    "anchor": "start"
  },
  "config": {"view": {"stroke": null}, "font": "Inter, system-ui, sans-serif"},
  "data": {"url": "https://raw.githubusercontent.com/ngoctuan3451/FIT2179/main/data/derived/aria_decades.json"},
  "transform": [{"filter": "datum.origin == 'Australian'"}],
  "layer": [
    {
      "mark": {"type": "bar", "cornerRadiusEnd": 4},
      "encoding": {
        "x": {
          "field": "decade",
          "type": "ordinal",
          "sort": ["1980s", "1990s", "2000s", "2010s", "2020s"],
          "title": null,
          "axis": {"labelFontSize": 13, "labelFontWeight": 600, "labelColor": "#333", "labelAngle": 0, "labelPadding": 8}
        },
        "xOffset": {"field": "format", "type": "nominal", "sort": ["Albums", "Singles"]},
        "y": {
          "field": "share",
          "type": "quantitative",
          "title": "% of chart weeks held by Australian artists",
          "scale": {"domain": [0, 30]},
          "axis": {"grid": true, "gridOpacity": 0.15, "labelFontSize": 11, "titleFontSize": 11, "titleColor": "#666"}
        },
        "color": {
          "field": "format",
          "type": "nominal",
          "scale": {"domain": ["Albums", "Singles"], "range": ["#2980b9", "#f39c12"]},
          "legend": {"orient": "bottom", "direction": "horizontal", "title": null, "labelFontSize": 13, "symbolSize": 200}
        },
        "tooltip": [
          {"field": "decade", "title": "Decade"},
          {"field": "format", "title": "Format"},
          {"field": "share",  "title": "Australian share %", "format": ".1f"},
          {"field": "weeks",  "title": "Australian weeks on chart"}
        ]
      }
    },
    {
      "mark": {"type": "text", "fontSize": 12, "fontWeight": 700, "color": "#1a1a2e", "dy": -6},
      "encoding": {
        "x": {"field": "decade", "type": "ordinal", "sort": ["1980s", "1990s", "2000s", "2010s", "2020s"]},
        "xOffset": {"field": "format", "type": "nominal", "sort": ["Albums", "Singles"]},
        "y": {"field": "share", "type": "quantitative"},
        "text": {"field": "share", "type": "quantitative", "format": ".0f"}
      }
    },
    {
      "data": {"values": [{"x": "2020s", "y": 26, "text": "First decade where Aussie singles\nshare finally lifted off zero"}]},
      "mark": {"type": "text", "fontSize": 11, "fontStyle": "italic", "color": "#c0392b", "align": "right", "dx": -20},
      "encoding": {
        "x": {"field": "x", "type": "ordinal", "sort": ["1980s", "1990s", "2000s", "2010s", "2020s"]},
        "y": {"field": "y", "type": "quantitative"},
        "text": {"field": "text"}
      }
    }
  ]
}

{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 380,
  "title": {
    "text": "Australian number 1 albums rise and fall by year",
    "subtitle": "Weeks per year when an Australian album was #1 on ARIA, 1988-2025. Max = 52 weeks.",
    "fontSize": 19,
    "subtitleFontSize": 12,
    "font": "Playfair Display",
    "subtitleColor": "#888",
    "anchor": "start"
  },
  "config": {"view": {"stroke": null}, "font": "Inter, system-ui, sans-serif"},
  "data": {"url": "https://raw.githubusercontent.com/ngoctuan3451/FIT2179/main/data/derived/aria_albums_yearly_origin.json"},
  "transform": [{"filter": "datum.origin == 'Australian'"}],
  "layer": [
    {
      "mark": {"type": "bar", "cornerRadiusEnd": 3, "color": "#00a99d"},
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": null,
          "axis": {"labelFontSize": 11, "labelAngle": 0, "labelColor": "#555", "values": [1988, 1992, 1996, 2000, 2004, 2008, 2012, 2016, 2020, 2024]}
        },
        "y": {
          "field": "weeks",
          "type": "quantitative",
          "title": "Weeks at #1 by an Australian album",
          "scale": {"domain": [0, 52]},
          "axis": {"grid": true, "gridOpacity": 0.15, "labelFontSize": 11, "titleFontSize": 11, "titleColor": "#666"}
        },
        "tooltip": [
          {"field": "year",  "title": "Year"},
          {"field": "weeks", "title": "Weeks at #1 (Australian)"}
        ]
      }
    },
    {
      "transform": [{"filter": "datum.weeks >= 15"}],
      "mark": {"type": "text", "fontSize": 11, "fontWeight": 700, "color": "#17131f", "dy": -6},
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {"field": "weeks", "type": "quantitative"},
        "text": {"field": "weeks"}
      }
    },
    {
      "mark": {"type": "rule", "color": "#888", "strokeDash": [4, 4], "strokeWidth": 1},
      "encoding": {"y": {"datum": 52}}
    },
    {
      "data": {"values": [{"x": 1988, "y": 52, "t": "52 weeks = whole year"}]},
      "mark": {"type": "text", "align": "left", "fontSize": 10, "color": "#777", "fontStyle": "italic", "dx": 4, "dy": -4},
      "encoding": {
        "x": {"field": "x", "type": "ordinal"},
        "y": {"field": "y", "type": "quantitative"},
        "text": {"field": "t"}
      }
    },
    {
      "data": {"values": [{"x": 2003, "y": 40, "t": "★ Delta Goodrem ruled 2003 (29 weeks at #1)"}]},
      "mark": {"type": "text", "fontSize": 11, "fontWeight": 700, "fontStyle": "italic", "color": "#b92752", "align": "center"},
      "encoding": {
        "x": {"field": "x", "type": "ordinal"},
        "y": {"field": "y", "type": "quantitative"},
        "text": {"field": "t"}
      }
    }
  ]
}

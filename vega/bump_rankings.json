    {
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 400,
  "title": {
    "text": "Australia's Chart Royalty: Year by Year",
    "subtitle": "Annual ranking of the top 8 Australian artists by weeks on ARIA singles chart (2018–2025)",
    "fontSize": 18,
    "subtitleFontSize": 12,
    "font": "Playfair Display",
    "subtitleColor": "#888",
    "anchor": "start"
  },
  "data": {
    "url": "https://raw.githubusercontent.com/ngoctuan3451/FIT2179/main/data/single_charts.csv"
  },
  "transform": [
    {
      "calculate": "datum.aus_flag == 'TRUE' || datum.aus_flag == 'True' || datum.aus_flag == true ? 1 : 0",
      "as": "is_aussie"
    },
    {"filter": "datum.is_aussie == 1"},
    {
      "timeUnit": "year",
      "field": "chart_date",
      "as": "year"
    },
    {"filter": "year(datum.year) >= 2018"},
    {
      "aggregate": [{"op": "count", "as": "weeks"}],
      "groupby": ["year", "artist"]
    },
    {
      "window": [{"op": "rank", "as": "rank"}],
      "sort": [{"field": "weeks", "order": "descending"}],
      "groupby": ["year"]
    },
    {"filter": "datum.rank <= 8"}
  ],
  "layer": [
    {
      "mark": {
        "type": "line",
        "strokeWidth": 3,
        "interpolate": "monotone",
        "point": {
          "filled": true,
          "size": 150,
          "stroke": "white",
          "strokeWidth": 2
        }
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "temporal",
          "title": null,
          "axis": {"format": "%Y", "labelFontSize": 11, "grid": false}
        },
        "y": {
          "field": "rank",
          "type": "quantitative",
          "title": "Rank",
          "scale": {"domain": [8.5, 0.5], "reverse": false},
          "axis": {"tickCount": 8, "labelFontSize": 11, "grid": true, "gridOpacity": 0.2}
        },
        "color": {
          "field": "artist",
          "type": "nominal",
          "title": "Artist",
          "scale": {"scheme": "tableau10"},
          "legend": {"labelLimit": 200}
        },
        "tooltip": [
          {"field": "artist", "title": "Artist"},
          {"field": "year", "type": "temporal", "title": "Year", "format": "%Y"},
          {"field": "rank", "title": "Rank"},
          {"field": "weeks", "title": "Weeks on Chart"}
        ]
      }
    }
  ]
}
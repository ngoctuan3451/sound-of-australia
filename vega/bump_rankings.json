{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 440,
  "padding": {"left": 20, "right": 20, "top": 10, "bottom": 10},
  "title": {
    "text": "Tones and I's three-year reign, then a streaming shake-up",
    "subtitle": "Top 5 Australian artists by weeks on chart, each year from 2018. Hover any line to highlight one artist.",
    "fontSize": 19,
    "subtitleFontSize": 12,
    "font": "Playfair Display",
    "subtitleColor": "#888",
    "anchor": "start",
    "offset": 14
  },
  "config": {"view": {"stroke": null}, "font": "Inter, system-ui, sans-serif"},
  "data": {"url": "https://raw.githubusercontent.com/ngoctuan3451/FIT2179/main/data/derived/aria_bump_rankings.json"},
  "encoding": {
    "x": {
      "field": "year",
      "type": "quantitative",
      "title": null,
      "axis": {"format": "d", "labelFontSize": 12, "labelColor": "#555", "grid": false, "domain": false, "ticks": false, "labelPadding": 10, "values": [2018, 2019, 2020, 2021, 2022, 2023, 2024, 2025]},
      "scale": {"domain": [2018, 2025], "nice": false, "padding": 28}
    },
    "y": {
      "field": "rank",
      "type": "quantitative",
      "title": null,
      "scale": {"domain": [5.5, 0.5]},
      "axis": {"values": [1, 2, 3, 4, 5], "labelExpr": "'#' + datum.value", "labelFontSize": 13, "labelFontWeight": 700, "labelColor": "#aaa", "labelPadding": 12, "grid": true, "gridDash": [3, 5], "gridColor": "#e0e0e0", "domain": false, "ticks": false}
    },
    "color": {
      "field": "artist",
      "type": "nominal",
      "scale": {"scheme": "tableau10"},
      "legend": {"title": null, "labelFontSize": 11, "labelFontWeight": 500, "symbolSize": 160, "symbolStrokeWidth": 3, "orient": "bottom", "direction": "horizontal", "columns": 0, "labelLimit": 220, "padding": 6}
    }
  },
  "layer": [
    {
      "mark": {"type": "line", "strokeWidth": 3.5, "interpolate": "monotone"},
      "encoding": {
        "detail": {"field": "artist"},
        "opacity": {"condition": {"param": "bumpHover", "value": 1, "empty": true}, "value": 0.08}
      }
    },
    {
      "params": [{"name": "bumpHover", "select": {"type": "point", "fields": ["artist"], "on": "mouseover", "clear": "mouseout"}}],
      "mark": {"type": "circle", "size": 200, "stroke": "white", "strokeWidth": 2.5},
      "encoding": {
        "opacity": {"condition": {"param": "bumpHover", "value": 1, "empty": true}, "value": 0.1},
        "tooltip": [
          {"field": "artist", "title": "Artist"},
          {"field": "year",   "title": "Year"},
          {"field": "rank",   "title": "Rank"},
          {"field": "weeks",  "title": "Weeks on chart"}
        ]
      }
    },
    {
      "mark": {"type": "text", "fontSize": 9, "fontWeight": 700, "color": "white", "baseline": "middle"},
      "encoding": {
        "text": {"field": "rank"},
        "opacity": {"condition": {"param": "bumpHover", "value": 1, "empty": true}, "value": 0.1}
      }
    },
    {
      "data": {"values": [
        {"x": 2020, "y": 0.75, "t": "Tones and I held #1 three years running"},
        {"x": 2023.2, "y": 0.75, "t": "Streaming-era newcomers take over"}
      ]},
      "mark": {"type": "text", "fontSize": 10, "fontStyle": "italic", "fontWeight": 600, "align": "center"},
      "encoding": {
        "x": {"field": "x", "type": "quantitative"},
        "y": {"field": "y", "type": "quantitative"},
        "text": {"field": "t"},
        "color": {"value": "#c0392b"},
        "opacity": {"value": 1}
      }
    }
  ]
}

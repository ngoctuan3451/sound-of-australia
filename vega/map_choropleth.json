{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 440,
  "title": {
    "text": "Three countries supply most of Australia's album chart",
    "subtitle": "Each country shaded by how many weeks its artists have spent on the ARIA album chart. The USA, Australia and the UK do most of the heavy lifting; Sweden punches well above its weight.",
    "fontSize": 19,
    "subtitleFontSize": 12,
    "font": "Playfair Display",
    "subtitleColor": "#888",
    "anchor": "start"
  },
  "config": {"view": {"stroke": null}, "font": "Inter, system-ui, sans-serif"},
  "projection": {"type": "equalEarth"},
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/FIT3179/Vega-Lite/main/2_symbol_map/js/ne_110m_admin_0_countries.topojson",
        "format": {"type": "topojson", "feature": "ne_110m_admin_0_countries"}
      },
      "mark": {"type": "geoshape", "fill": "#e8e8e8", "stroke": "white", "strokeWidth": 0.4}
    },
    {
      "data": {"url": "https://raw.githubusercontent.com/ngoctuan3451/FIT2179/main/data/derived/aria_country_totals.json"},
      "transform": [
        {
          "calculate": "datum.location == 'United States' ? 'United States of America' : datum.location",
          "as": "location_fixed"
        },
        {
          "lookup": "location_fixed",
          "from": {
            "data": {
              "url": "https://raw.githubusercontent.com/FIT3179/Vega-Lite/main/2_symbol_map/js/ne_110m_admin_0_countries.topojson",
              "format": {"type": "topojson", "feature": "ne_110m_admin_0_countries"}
            },
            "key": "properties.NAME",
            "fields": ["type", "properties", "geometry"]
          }
        }
      ],
      "mark": {"type": "geoshape", "stroke": "white", "strokeWidth": 0.4},
      "encoding": {
        "shape": {"field": "geometry", "type": "geojson"},
        "color": {
          "field": "weeks",
          "type": "quantitative",
          "scale": {"type": "log", "scheme": "yelloworangered"},
          "legend": {
            "title": "Weeks on chart",
            "format": ",",
            "orient": "bottom-right",
            "gradientLength": 140
          }
        },
        "tooltip": [
          {"field": "location_fixed", "title": "Country"},
          {"field": "weeks", "title": "Weeks on chart", "format": ","}
        ]
      }
    },
    {
      "data": {
        "values": [
          {"label": "★ #1", "sub": "USA", "lon": -100, "lat": 40},
          {"label": "#2", "sub": "Australia", "lon": 134, "lat": -28},
          {"label": "#3", "sub": "UK", "lon": -25, "lat": 58},
          {"label": "#4", "sub": "Canada", "lon": -96, "lat": 67},
          {"label": "#5", "sub": "Ireland", "lon": -25, "lat": 48},
          {"label": "#6", "sub": "Sweden", "lon": 32, "lat": 67}
        ]
      },
      "layer": [
        {
          "mark": {"type": "text", "fontSize": 13, "fontWeight": 800, "stroke": "white", "strokeWidth": 3, "dy": -7},
          "encoding": {
            "longitude": {"field": "lon"},
            "latitude": {"field": "lat"},
            "text": {"field": "label"},
            "color": {"value": "#c0392b"}
          }
        },
        {
          "mark": {"type": "text", "fontSize": 13, "fontWeight": 800, "dy": -7},
          "encoding": {
            "longitude": {"field": "lon"},
            "latitude": {"field": "lat"},
            "text": {"field": "label"},
            "color": {"value": "#c0392b"}
          }
        },
        {
          "mark": {"type": "text", "fontSize": 10, "fontWeight": 600, "stroke": "white", "strokeWidth": 3, "dy": 6},
          "encoding": {
            "longitude": {"field": "lon"},
            "latitude": {"field": "lat"},
            "text": {"field": "sub"},
            "color": {"value": "#333"}
          }
        },
        {
          "mark": {"type": "text", "fontSize": 10, "fontWeight": 600, "dy": 6},
          "encoding": {
            "longitude": {"field": "lon"},
            "latitude": {"field": "lat"},
            "text": {"field": "sub"},
            "color": {"value": "#333"}
          }
        }
      ]
    }
  ]
}

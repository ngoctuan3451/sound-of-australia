{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 380,
  "title": {
    "text": "New songs arrive all year — then go quiet at Christmas",
    "subtitle": "Total number of brand-new entries onto the ARIA singles chart in each calendar month, summed across 37 years (1988–2024). Record labels release steadily from autumn to spring, then ease off over the summer holidays.",
    "fontSize": 19,
    "subtitleFontSize": 12,
    "font": "Playfair Display",
    "subtitleColor": "#888",
    "anchor": "start"
  },
  "config": {"view": {"stroke": null}, "font": "Inter, system-ui, sans-serif"},
  "data": {"url": "https://raw.githubusercontent.com/ngoctuan3451/FIT2179/main/data/derived/aria_seasonality.json"},
  "transform": [
    {"aggregate": [{"op": "sum", "field": "debuts", "as": "total"}], "groupby": ["month", "label"]}
  ],
  "encoding": {
    "x": {
      "field": "month",
      "type": "ordinal",
      "title": null,
      "axis": {"labelFontSize": 13, "labelFontWeight": 600, "labelColor": "#333", "labelAngle": 0, "domain": false, "ticks": false, "labelExpr": "['','Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][datum.value]"}
    },
    "y": {
      "field": "total",
      "type": "quantitative",
      "title": "New chart entries that month (1988–2024)",
      "scale": {"domain": [0, 900]},
      "axis": {"grid": true, "gridOpacity": 0.15, "labelFontSize": 11, "titleFontSize": 11, "titleColor": "#666"}
    }
  },
  "layer": [
    {
      "mark": {"type": "area", "interpolate": "monotone", "line": {"color": "#1a4a6b", "strokeWidth": 3}, "color": {"x1": 1, "y1": 1, "x2": 1, "y2": 0, "gradient": "linear", "stops": [{"offset": 0, "color": "#eaf2f8"}, {"offset": 1, "color": "#7fb3d5"}]}}
    },
    {
      "mark": {"type": "point", "filled": true, "size": 90, "color": "#1a4a6b", "stroke": "white", "strokeWidth": 1.5},
      "encoding": {
        "tooltip": [
          {"field": "label", "title": "Month"},
          {"field": "total", "title": "New chart entries"}
        ]
      }
    },
    {
      "transform": [{"filter": "datum.label == 'Dec'"}],
      "mark": {"type": "point", "filled": true, "size": 150, "color": "#c0392b", "stroke": "white", "strokeWidth": 2}
    },
    {
      "transform": [{"filter": "datum.label == 'Dec'"}],
      "mark": {"type": "text", "align": "right", "dx": -10, "dy": -4, "fontSize": 11, "fontStyle": "italic", "fontWeight": 700, "color": "#c0392b", "lineBreak": "|", "lineHeight": 13},
      "encoding": {"text": {"value": "Quietest month:|the Christmas slowdown"}}
    },
    {
      "transform": [{"filter": "datum.label == 'May'"}],
      "mark": {"type": "text", "align": "center", "dy": -16, "fontSize": 11, "fontStyle": "italic", "fontWeight": 700, "color": "#1a4a6b"},
      "encoding": {"text": {"value": "Busiest month for new releases"}}
    }
  ]
}

{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 460,
  "height": 460,
  "title": {
    "text": "When new singles hit the ARIA chart, by month",
    "subtitle": "Radial bars show the number of first-ever debuts on the ARIA singles chart by calendar month, split by Australian (orange) and international (navy) artists.",
    "fontSize": 19,
    "subtitleFontSize": 12,
    "font": "Playfair Display",
    "subtitleColor": "#888",
    "anchor": "start",
    "offset": 20
  },
  "config": {"view": {"stroke": null}, "font": "Inter, system-ui, sans-serif"},
  "data": {"url": "https://raw.githubusercontent.com/ngoctuan3451/FIT2179/main/data/derived/aria_seasonality.json"},
  "layer": [
    {
      "mark": {"type": "arc", "innerRadius": 60, "stroke": "white", "strokeWidth": 1.5},
      "encoding": {
        "theta": {
          "field": "month",
          "type": "ordinal",
          "scale": {"type": "band"}
        },
        "radius": {
          "field": "debuts",
          "type": "quantitative",
          "scale": {"type": "sqrt", "zero": true, "rangeMin": 60}
        },
        "color": {
          "field": "origin",
          "type": "nominal",
          "scale": {"domain": ["Australian", "International"], "range": ["#f39c12", "#1a1a2e"]},
          "legend": {"orient": "bottom", "direction": "horizontal", "title": null, "labelFontSize": 12, "symbolSize": 180}
        },
        "order": {"field": "origin"},
        "tooltip": [
          {"field": "label",  "title": "Month"},
          {"field": "origin", "title": "Origin"},
          {"field": "debuts", "title": "New debuts"}
        ]
      }
    },
    {
      "mark": {"type": "text", "radiusOffset": 16, "fontSize": 12, "fontWeight": 700, "color": "#333"},
      "encoding": {
        "theta": {"field": "month", "type": "ordinal", "scale": {"type": "band"}},
        "radius": {"value": 200},
        "text": {"field": "label"},
        "detail": {"aggregate": "max", "field": "month"}
      }
    }
  ]
}

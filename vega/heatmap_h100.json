{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 460,
  "padding": {"left": 10, "right": 10, "top": 10, "bottom": 10},
  "title": {
    "text": "Triple J Royalty: Who Keeps Coming Back",
    "subtitle": "The 25 artists with the most entries across every Hottest 100 (1993–2025). Darker cells = more songs that year.",
    "fontSize": 18,
    "subtitleFontSize": 12,
    "font": "Playfair Display",
    "subtitleColor": "#888",
    "anchor": "start",
    "offset": 14
  },
  "config": {
    "view": {"stroke": null},
    "font": "Inter, system-ui, sans-serif",
    "axis": {"domain": false, "ticks": false}
  },
  "data": {"url": "https://raw.githubusercontent.com/ngoctuan3451/FIT2179/main/data/derived/h100_heatmap.json"},
  "layer": [
    {
      "mark": {"type": "rect", "stroke": "#fafafa", "strokeWidth": 1},
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": null,
          "axis": {"labelAngle": 0, "labelFontSize": 9, "labelOverlap": true, "labelColor": "#777"}
        },
        "y": {
          "field": "artist",
          "type": "nominal",
          "sort": {"field": "total", "op": "max", "order": "descending"},
          "title": null,
          "axis": {
            "labelFontSize": 11,
            "labelColor": "#333",
            "labelLimit": 200,
            "labelExpr": "datum.value == 'Hilltop Hoods' ? '★ ' + datum.value : datum.value",
            "labelFontWeight": {"expr": "datum.value == 'Hilltop Hoods' ? 700 : 400"}
          }
        },
        "color": {
          "field": "count",
          "type": "quantitative",
          "scale": {"scheme": "oranges", "domainMin": 0},
          "legend": {"title": "Songs in poll", "orient": "bottom", "gradientLength": 220, "titleFontSize": 11, "labelFontSize": 10}
        },
        "tooltip": [
          {"field": "artist", "title": "Artist"},
          {"field": "year", "title": "Poll year"},
          {"field": "count", "title": "Songs in this poll"},
          {"field": "total", "title": "Total all-time entries"}
        ]
      }
    },
    {
      "transform": [
        {"filter": "datum.count >= 4"}
      ],
      "mark": {"type": "text", "fontSize": 9, "fontWeight": 700, "color": "white"},
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {"field": "artist", "type": "nominal", "sort": {"field": "total", "op": "max", "order": "descending"}},
        "text": {"field": "count"}
      }
    },
    {
      "transform": [
        {"filter": "datum.artist == 'Hilltop Hoods' && datum.year == 2025"}
      ],
      "mark": {"type": "text", "fontSize": 10, "fontWeight": 700, "fontStyle": "italic", "color": "#c0392b", "align": "right", "baseline": "bottom", "dx": -6, "dy": -8},
      "encoding": {
        "y": {"field": "artist", "type": "nominal"},
        "x": {"field": "year", "type": "ordinal"},
        "text": {"value": "★ Most-played in Triple J history"}
      }
    }
  ]
}

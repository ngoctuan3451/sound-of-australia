{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 460,
  "padding": {"left": 10, "right": 10, "top": 10, "bottom": 10},
  "title": {
    "text": "Triple J listeners keep voting for these artists",
    "subtitle": "Top 25 artists by regular Hottest 100 entries, 1993-2025. Darker cells = more songs that year.",
    "fontSize": 19,
    "subtitleFontSize": 12,
    "font": "Playfair Display",
    "subtitleColor": "#888",
    "anchor": "start",
    "offset": 14
  },
  "config": {
    "view": {"stroke": null},
    "font": "Inter, system-ui, sans-serif",
    "axis": {"domain": false, "ticks": false}
  },
  "data": {
    "url": "https://raw.githubusercontent.com/ngoctuan3451/FIT2179/main/data/derived/h100_heatmap.json"
  },
  "params": [
    {
      "name": "artistFocus",
      "value": "All artists",
      "bind": {
        "input": "select",
        "name": "Focus artist: ",
        "options": [
          "All artists",
          "Hilltop Hoods",
          "Billie Eilish",
          "Powderfinger",
          "G Flip",
          "Tame Impala",
          "Foo Fighters",
          "Spacey Jane",
          "Ocean Alley",
          "Silverchair",
          "Muse",
          "Lime Cordiale",
          "Grinspoon",
          "Kanye West",
          "The Living End",
          "Arctic Monkeys",
          "The Wombats",
          "Regurgitator",
          "Ball Park Music",
          "Bring Me The Horizon",
          "Placebo",
          "Flume",
          "You Am I",
          "Lorde",
          "Pearl Jam",
          "Kendrick Lamar"
        ]
      }
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "rect",
        "stroke": "#fafafa",
        "strokeWidth": 1,
        "cursor": "pointer"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": null,
          "axis": {
            "labelAngle": 0,
            "labelFontSize": 10,
            "labelColor": "#666",
            "values": [1993, 1997, 2001, 2005, 2009, 2013, 2017, 2021, 2025]
          }
        },
        "y": {
          "field": "artist",
          "type": "nominal",
          "sort": {"field": "total", "op": "max", "order": "descending"},
          "title": null,
          "axis": {
            "labelFontSize": 12,
            "labelLimit": 220,
            "labelColor": "#333"
          }
        },
        "color": {
          "field": "count",
          "type": "quantitative",
          "scale": {"domainMin": 0, "range": ["#fff4ea", "#ffd166", "#ff7aa2", "#ff4f7b", "#b92752"]},
          "legend": {
            "title": "Songs in poll",
            "orient": "bottom",
            "gradientLength": 220,
            "titleFontSize": 11,
            "labelFontSize": 10
          }
        },
        "opacity": {
          "condition": {
            "test": "artistFocus == 'All artists' || datum.artist == artistFocus",
            "value": 1
          },
          "value": 0.16
        },
        "tooltip": [
          {"field": "artist", "title": "Artist"},
          {"field": "year", "title": "Poll year"},
          {"field": "count", "title": "Songs in this poll"},
          {"field": "total", "title": "Total entries, 1993-2025"}
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "artistFocus != 'All artists' && datum.artist == artistFocus && datum.count > 0"
        }
      ],
      "mark": {
        "type": "text",
        "fontSize": 10,
        "fontWeight": 700
      },
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {
          "field": "artist",
          "type": "nominal",
          "sort": {"field": "total", "op": "max", "order": "descending"}
        },
        "text": {"field": "count"},
        "color": {
          "condition": {"test": "datum.count >= 3", "value": "white"},
          "value": "#17131f"
        }
      }
    }
  ]
}

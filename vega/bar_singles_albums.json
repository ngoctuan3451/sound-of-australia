{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 460,
  "title": {
    "text": "Singles vs Albums: Who Owns Which Format?",
    "subtitle": "Top 15 Australian artists by combined weeks on the ARIA charts, sorted by total. Some are album acts, others live on the singles chart.",
    "fontSize": 16,
    "subtitleFontSize": 12,
    "font": "Playfair Display",
    "subtitleColor": "#888",
    "anchor": "start"
  },
  "config": {"view": {"stroke": null}, "font": "Inter, system-ui, sans-serif"},
  "data": {"url": "https://raw.githubusercontent.com/ngoctuan3451/FIT2179/main/data/derived/aria_top_artists_format.json"},
  "layer": [
    {
      "mark": {"type": "bar", "cornerRadiusEnd": 3, "height": 10},
      "encoding": {
        "y": {
          "field": "artist",
          "type": "nominal",
          "sort": {"field": "total", "op": "max", "order": "descending"},
          "title": null,
          "axis": {"labelFontSize": 12, "labelLimit": 180, "labelColor": "#333"}
        },
        "yOffset": {"field": "format", "type": "nominal", "sort": ["Albums", "Singles"]},
        "x": {
          "field": "weeks",
          "type": "quantitative",
          "title": "Weeks on chart",
          "axis": {"grid": true, "gridOpacity": 0.15, "labelFontSize": 11, "titleFontSize": 11, "titleColor": "#666"}
        },
        "color": {
          "field": "format",
          "type": "nominal",
          "scale": {"domain": ["Albums", "Singles"], "range": ["#2980b9", "#f39c12"]},
          "legend": {"orient": "top-right", "title": null, "labelFontSize": 12, "symbolSize": 140}
        },
        "tooltip": [
          {"field": "artist", "title": "Artist"},
          {"field": "format", "title": "Format"},
          {"field": "weeks", "title": "Weeks on chart"},
          {"field": "total", "title": "Combined total"}
        ]
      }
    },
    {
      "mark": {"type": "text", "align": "left", "fontSize": 10, "color": "#555", "dx": 4},
      "encoding": {
        "y": {"field": "artist", "type": "nominal", "sort": {"field": "total", "op": "max", "order": "descending"}},
        "yOffset": {"field": "format", "type": "nominal", "sort": ["Albums", "Singles"]},
        "x": {"field": "weeks", "type": "quantitative"},
        "text": {"field": "weeks"}
      }
    }
  ]
}

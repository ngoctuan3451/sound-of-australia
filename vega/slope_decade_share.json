{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 420,
  "title": {
    "text": "Australian albums stayed stronger than singles",
    "subtitle": ["Australian share of ARIA charts by year, 1988-2025.", "Teal = albums; coral = singles. Press Play to trace both lines."],
    "fontSize": 19,
    "subtitleFontSize": 12,
    "font": "Playfair Display",
    "subtitleColor": "#888",
    "anchor": "start"
  },
  "config": {"view": {"stroke": null}, "font": "Inter, system-ui, sans-serif"},
  "data": {"url": "https://raw.githubusercontent.com/ngoctuan3451/FIT2179/main/data/derived/aria_share_yearly.json"},
  "params": [{"name": "playYear", "value": 0}],
  "encoding": {
    "x": {
      "field": "year",
      "type": "quantitative",
      "title": null,
      "scale": {"domain": [1988, 2025], "nice": false},
      "axis": {"values": [1988, 1992, 1996, 2000, 2004, 2008, 2012, 2016, 2020, 2024], "format": "d", "labelFontSize": 11, "labelColor": "#333", "domain": true, "domainColor": "#bbb", "ticks": true, "tickColor": "#bbb", "grid": false}
    },
    "y": {
      "field": "share",
      "type": "quantitative",
      "title": "Australian share of the chart (%)",
      "scale": {"domain": [0, 30]},
      "axis": {"grid": true, "gridOpacity": 0.15, "labelFontSize": 11, "titleFontSize": 11, "titleColor": "#666", "format": ".0f", "domain": true, "domainColor": "#bbb", "ticks": true, "tickColor": "#bbb"}
    },
    "color": {
      "field": "format",
      "type": "nominal",
      "scale": {"domain": ["Albums", "Singles"], "range": ["#00a99d", "#ff4f7b"]},
      "legend": {"orient": "top", "direction": "horizontal", "title": null, "labelFontSize": 13, "symbolSize": 220, "padding": 6}
    }
  },
  "layer": [
    {
      "mark": {"type": "line", "strokeWidth": 3, "interpolate": "monotone"},
      "encoding": {
        "detail": {"field": "format"},
        "opacity": {"condition": {"test": "playYear > 0", "value": 0.18}, "value": 1}
      }
    },
    {
      "mark": {"type": "point", "filled": true, "size": 45, "stroke": "white", "strokeWidth": 1},
      "encoding": {
        "opacity": {"condition": {"test": "playYear > 0", "value": 0.12}, "value": 0.9},
        "tooltip": [
          {"field": "year", "title": "Year"},
          {"field": "format", "title": "Chart"},
          {"field": "share", "title": "Australian share %", "format": ".1f"}
        ]
      }
    },
    {
      "transform": [{"filter": "playYear > 0 && datum.year <= playYear"}],
      "mark": {"type": "line", "strokeWidth": 4, "interpolate": "monotone"},
      "encoding": {"detail": {"field": "format"}}
    },
    {
      "transform": [{"filter": "datum.year == playYear"}],
      "mark": {"type": "point", "filled": true, "size": 170, "stroke": "white", "strokeWidth": 2}
    },
    {
      "data": {"values": [{"year": 1991, "y": 27.5, "t": "Both near 25% in the late 1980s"}]},
      "mark": {"type": "text", "align": "left", "dx": 8, "fontSize": 11, "fontStyle": "italic", "fontWeight": 700, "color": "#5e5a68", "stroke": "white", "strokeWidth": 2.5},
      "encoding": {
        "x": {"field": "year", "type": "quantitative"},
        "y": {"field": "y", "type": "quantitative"},
        "text": {"field": "t"}
      }
    },
    {
      "data": {"values": [{"year": 2015, "y": 5, "t": "Singles under 10% and still falling"}]},
      "mark": {"type": "text", "align": "right", "dx": -4, "fontSize": 11, "fontStyle": "italic", "fontWeight": 700, "color": "#b92752", "stroke": "white", "strokeWidth": 2.5},
      "encoding": {
        "x": {"field": "year", "type": "quantitative"},
        "y": {"field": "y", "type": "quantitative"},
        "text": {"field": "t"}
      }
    }
  ]
}

{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 420,
  "padding": {"left": 18, "right": 70},
  "title": {
    "text": "Australia held the album chart while its singles share slipped",
    "subtitle": ["Share of the ARIA chart held by Australian artists, by decade. In the 1980s Australia held about a quarter of BOTH charts.", "Albums (blue) stayed near a quarter for 30 years; singles (orange) drifted down into single digits."],
    "fontSize": 19,
    "subtitleFontSize": 12,
    "font": "Playfair Display",
    "subtitleColor": "#888",
    "anchor": "start"
  },
  "config": {"view": {"stroke": null}, "font": "Inter, system-ui, sans-serif"},
  "data": {"url": "https://raw.githubusercontent.com/ngoctuan3451/FIT2179/main/data/derived/aria_decades.json"},
  "transform": [
    {"filter": "datum.origin == 'Australian'"},
    {"calculate": "parseInt(datum.decade)", "as": "dec"}
  ],
  "encoding": {
    "x": {
      "field": "dec",
      "type": "quantitative",
      "title": null,
      "scale": {"domain": [1980, 2020], "nice": false},
      "axis": {"values": [1980, 1990, 2000, 2010, 2020], "labelExpr": "datum.value + 's'", "labelFontSize": 14, "labelFontWeight": 600, "labelColor": "#333", "labelAngle": 0, "labelPadding": 12, "domain": true, "domainColor": "#bbb", "ticks": true, "tickColor": "#bbb", "grid": false}
    },
    "y": {
      "field": "share",
      "type": "quantitative",
      "title": "Australian share of the chart (%)",
      "scale": {"domain": [0, 30]},
      "axis": {"grid": true, "gridOpacity": 0.15, "labelFontSize": 11, "titleFontSize": 11, "titleColor": "#666", "format": ".0f", "domain": true, "domainColor": "#bbb", "ticks": true, "tickColor": "#bbb"}
    },
    "color": {
      "field": "format",
      "type": "nominal",
      "scale": {"domain": ["Albums", "Singles"], "range": ["#2980b9", "#f39c12"]},
      "legend": null
    }
  },
  "layer": [
    {
      "mark": {"type": "line", "strokeWidth": 4, "interpolate": "monotone"},
      "encoding": {"detail": {"field": "format"}}
    },
    {
      "mark": {"type": "point", "filled": true, "size": 300, "stroke": "white", "strokeWidth": 2.5},
      "encoding": {
        "tooltip": [
          {"field": "decade", "title": "Decade"},
          {"field": "format", "title": "Chart"},
          {"field": "share",  "title": "Australian share %", "format": ".1f"},
          {"field": "weeks",  "title": "Australian chart-weeks"}
        ]
      }
    },
    {
      "mark": {"type": "text", "fontSize": 10, "fontWeight": 700, "color": "white"},
      "encoding": {
        "text": {"field": "share", "type": "quantitative", "format": ".0f"}
      }
    },
    {
      "transform": [{"filter": "datum.dec == 2020"}],
      "mark": {"type": "text", "align": "left", "dx": 16, "fontSize": 14, "fontWeight": 700, "baseline": "middle"},
      "encoding": {
        "text": {"field": "format"},
        "color": {"field": "format", "type": "nominal"}
      }
    },
    {
      "data": {"values": [{"dec": 1980, "y": 28.5, "t": "Both near a quarter in the 1980s"}]},
      "mark": {"type": "text", "fontSize": 11, "fontStyle": "italic", "fontWeight": 700, "color": "#c0392b", "align": "left", "dx": -4, "dy": 0},
      "encoding": {
        "x": {"field": "dec", "type": "quantitative"},
        "y": {"field": "y", "type": "quantitative"},
        "text": {"field": "t"},
        "color": {"value": "#c0392b"}
      }
    }
  ]
}

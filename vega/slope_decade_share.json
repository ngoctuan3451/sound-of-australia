{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 420,
  "padding": {"right": 70},
  "title": {
    "text": "Australia competes on albums — but barely on singles",
    "subtitle": "Share of the ARIA chart held by Australian artists, by decade. On the ALBUMS chart (blue) Australia has always had a real presence. On the SINGLES chart (orange) it sat at zero for 30 years — until streaming arrived.",
    "fontSize": 19,
    "subtitleFontSize": 12,
    "font": "Playfair Display",
    "subtitleColor": "#888",
    "anchor": "start"
  },
  "config": {"view": {"stroke": null}, "font": "Inter, system-ui, sans-serif"},
  "data": {"url": "https://raw.githubusercontent.com/ngoctuan3451/FIT2179/main/data/derived/aria_decades.json"},
  "transform": [{"filter": "datum.origin == 'Australian'"}],
  "encoding": {
    "x": {
      "field": "decade",
      "type": "ordinal",
      "sort": ["1980s", "1990s", "2000s", "2010s", "2020s"],
      "title": null,
      "axis": {"labelFontSize": 14, "labelFontWeight": 600, "labelColor": "#333", "labelAngle": 0, "labelPadding": 12, "domain": false, "ticks": false}
    },
    "y": {
      "field": "share",
      "type": "quantitative",
      "title": "Australian share of the chart (%)",
      "scale": {"domain": [0, 30]},
      "axis": {"grid": true, "gridOpacity": 0.15, "labelFontSize": 11, "titleFontSize": 11, "titleColor": "#666", "format": ".0f"}
    },
    "color": {
      "field": "format",
      "type": "nominal",
      "scale": {"domain": ["Albums", "Singles"], "range": ["#2980b9", "#f39c12"]},
      "legend": null
    }
  },
  "layer": [
    {
      "mark": {"type": "line", "strokeWidth": 4, "interpolate": "monotone"},
      "encoding": {"detail": {"field": "format"}}
    },
    {
      "mark": {"type": "point", "filled": true, "size": 300, "stroke": "white", "strokeWidth": 2.5},
      "encoding": {
        "tooltip": [
          {"field": "decade", "title": "Decade"},
          {"field": "format", "title": "Chart"},
          {"field": "share",  "title": "Australian share %", "format": ".1f"},
          {"field": "weeks",  "title": "Australian chart-weeks"}
        ]
      }
    },
    {
      "mark": {"type": "text", "fontSize": 10, "fontWeight": 700, "color": "white"},
      "encoding": {
        "text": {"field": "share", "type": "quantitative", "format": ".0f"}
      }
    },
    {
      "transform": [{"filter": "datum.decade == '2020s'"}],
      "mark": {"type": "text", "align": "left", "dx": 16, "fontSize": 14, "fontWeight": 700, "baseline": "middle"},
      "encoding": {
        "text": {"field": "format"},
        "color": {"field": "format", "type": "nominal"}
      }
    },
    {
      "data": {"values": [{"decade": "2010s", "y": 6, "t": "Streaming finally lifts"}, {"decade": "2010s", "y": 3.4, "t": "Aussie singles off zero"}]},
      "mark": {"type": "text", "fontSize": 11, "fontStyle": "italic", "fontWeight": 700, "color": "#c0392b", "align": "center", "dy": 0},
      "encoding": {
        "x": {"field": "decade", "type": "ordinal", "sort": ["1980s","1990s","2000s","2010s","2020s"]},
        "y": {"field": "y", "type": "quantitative"},
        "text": {"field": "t"},
        "color": {"value": "#c0392b"}
      }
    }
  ]
}
